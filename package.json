{
  "name": "clutch-chess",
  "version": "1.0.0",
  "description": "Real-time multiplayer chess with no turns - both players move simultaneously",
  "type": "module",
  "scripts": {
    "dev": "concurrently \"npm run dev:client\" \"npm run dev:server\"",
    "dev:client": "vite",
    "dev:server": "node --watch server/index.js",
    "build": "vite build",
    "preview": "vite preview",
    "test": "vitest"
  },
  "dependencies": {
    "bcryptjs": "^3.0.3",
    "express": "^4.18.2",
    "jsonwebtoken": "^9.0.3",
    "socket.io": "^4.7.2",
    "socket.io-client": "^4.7.2",
    "three": "^0.160.1",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "concurrently": "^8.2.2",
    "vite": "^5.0.10",
    "vitest": "^1.1.0"
  }
}
